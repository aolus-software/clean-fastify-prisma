{
	"compilerOptions": {
		"target": "ES2022",
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"baseUrl": ".",
		"declaration": true,
		"sourceMap": true,
		"outDir": "./dist",
		"removeComments": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"noImplicitThis": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": false,
		"skipLibCheck": true,
		"types": ["node"],
		"typeRoots": ["./node_modules/@types", "./types"],
		"paths": {
			"@/*": ["src/*"],
			"@libs/*": ["./src/libs/*"],
			"@libs": ["./src/libs", "./src/libs/index.ts"],
			"@cache/*": ["./src/libs/cache/*"],
			"@cache": ["./src/libs/cache", "./src/libs/cache/index.ts"],
			"@config/*": ["./src/libs/config/*"],
			"@config": ["./src/libs/config", "./src/libs/config/index.ts"],
			"@database/*": ["./src/libs/database/*"],
			"@database": ["./src/libs/database", "./src/libs/database/index.ts"],
			"@fastify-libs/*": ["./src/libs/fastify/*"],
			"@fastify-libs": ["./src/libs/fastify", "./src/libs/fastify/index.ts"],
			"@utils/*": ["./src/libs/utils/*"],
			"@utils": ["./src/libs/utils", "./src/libs/utils/index.ts"],
			"@bull/*": ["./src/bull/*"],
			"@bull": ["./src/bull", "./src/bull/index.ts"],
			"@types/*": ["./src/libs/types/*"],
			"@types": ["./src/libs/types", "./src/libs/types/index.ts"],
			"@modules/*": ["./src/modules/*"],
			"@modules": ["./src/modules", "./src/modules/index.ts"],
			"@prisma-generated": ["./prisma/generated/client"]
		}
	},
	"include": ["src", "prisma/seed", "eslint.config.mjs", "prisma.config.ts"],
	"exclude": ["node_modules", "dist"]
}
