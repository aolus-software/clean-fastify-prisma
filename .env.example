# App
APP_NAME="Fastify Prisma App"
APP_PORT=3000
APP_URL=http://localhost:3000
APP_ENV=development
APP_TIMEZONE=UTC
APP_KEY=your-app-key-32-chars-minimum
APP_JWT_SECRET=your-jwt-secret
APP_JWT_EXPIRES_IN=3600
APP_JWT_REFRESH_SECRET=your-jwt-refresh-secret
APP_JWT_REFRESH_EXPIRES_IN=604800
LOG_LEVEL=info
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastify_prisma"
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password123
REDIS_DB=0

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_EXPOSED_HEADERS=
CORS_MAX_AGE=86400
CORS_CREDENTIALS=false

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_FROM="App <noreply@example.com>"
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_password
